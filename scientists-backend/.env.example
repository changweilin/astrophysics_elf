# Scientists backend configuration. Copy to `.env` and adjust, or set these as
# real environment variables. All are optional -- defaults are shown.

# --- HTTP server ---
SCI_HOST=127.0.0.1
SCI_PORT=5188
# Comma-separated allowed CORS origins, or * to echo any (fine for local use).
SCI_CORS_ORIGINS=*

# --- Inference engine (Ollama) ---
SCI_OLLAMA_URL=http://127.0.0.1:11434
SCI_DEFAULT_LANG=zh

# Per-language models (switching UI language switches the model).
# Traditional Chinese (Taiwan): strongest Taiwan-localized 8B that fits a 3060.
SCI_MODEL_ZH=jcai/llama-3-taiwan-8b-instruct
# English: Phi-4 (14B) leads STEM/math at this tier. Tight on 12GB -- if you run
# out of VRAM, switch to qwen3:8b or lower SCI_CONTEXT_TOKENS_EN.
SCI_MODEL_EN=phi4

# Optional smaller models used only for summarization (default: the main model).
#SCI_SUMMARY_MODEL_ZH=qwen3:4b
#SCI_SUMMARY_MODEL_EN=phi4-mini

# Sampling
SCI_TEMPERATURE=0.6
SCI_TOP_P=0.9
SCI_REQUEST_TIMEOUT_MS=300000

# --- Context window management ---
# Usable context per language (match the num_ctx your GPU can hold).
SCI_CONTEXT_TOKENS_ZH=8192
SCI_CONTEXT_TOKENS_EN=8192
# Summarize + restart when usage reaches this fraction of the window (0.70 = 70%).
SCI_SUMMARIZE_AT=0.7
SCI_REPLY_RESERVE=1024
# Cap how many replayed turns a resumed thread seeds back into context.
SCI_REHYDRATE_MAX_MESSAGES=80

# --- Follow-up question suggestions (after each turn). On by default. ---
SCI_FOLLOWUPS=1
SCI_FOLLOWUPS_CONTEXT_TURNS=6
SCI_FOLLOWUPS_TOKENS=256

# --- Wikipedia retrieval (RAG). Off by default. ---
SCI_WIKI_RAG=0
SCI_WIKI_LANG=zh
SCI_WIKI_ZH_VARIANT=zh-tw
SCI_WIKI_MAX_CHARS=1500
# Local wiki knowledge base (wiki-kb/server.mjs). When set, RAG asks the
# offline KB first (hybrid BM25+vector, time decay) and falls back to live
# Wikipedia if it is down or empty-handed.
#SCI_WIKI_KB_URL=http://127.0.0.1:5189
